<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEON STRIKE — 3D Arena Shooter</title>
<style>
  :root { --neon: #00f0ff; --hot: #ff2e88; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #05060c; }
  body { font-family: "Segoe UI", system-ui, sans-serif; color: #e8f6ff; cursor: default; }
  #game { display: block; width: 100vw; height: 100vh; }

  /* HUD */
  #hud { position: fixed; inset: 0; pointer-events: none; z-index: 5; }
  #crosshair {
    position: absolute; left: 50%; top: 50%; width: 26px; height: 26px;
    transform: translate(-50%, -50%); opacity: 0.9;
  }
  #crosshair::before, #crosshair::after {
    content: ""; position: absolute; background: var(--neon);
    box-shadow: 0 0 6px var(--neon);
  }
  #crosshair::before { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }
  #crosshair::after { top: 50%; left: 0; height: 2px; width: 100%; transform: translateY(-50%); }
  #crosshair .dot {
    position: absolute; left: 50%; top: 50%; width: 4px; height: 4px; border-radius: 50%;
    background: var(--hot); transform: translate(-50%,-50%); box-shadow: 0 0 8px var(--hot);
  }

  .panel { position: absolute; text-shadow: 0 0 8px currentColor; font-weight: 700; letter-spacing: 1px; }
  #score { top: 22px; left: 28px; font-size: 14px; color: #9fe9ff; }
  #score b { font-size: 30px; color: #fff; display:block; margin-top:2px; }
  #wave  { top: 22px; right: 28px; font-size: 14px; color: #ffd27a; text-align:right; }
  #wave b { font-size: 30px; color: #fff; display:block; margin-top:2px; }

  #healthwrap { position:absolute; bottom: 28px; left: 28px; width: 280px; }
  #healthlabel { font-size: 12px; color:#ff8fb4; letter-spacing:2px; margin-bottom:6px; text-shadow:0 0 8px #ff2e88;}
  #healthbar { height: 16px; background: rgba(255,46,136,0.12); border: 1px solid rgba(255,46,136,0.5);
               border-radius: 8px; overflow:hidden; }
  #healthfill { height:100%; width:100%; background: linear-gradient(90deg,#ff2e88,#ff6ec4);
                box-shadow: 0 0 14px #ff2e88; transition: width 0.15s ease; }

  #ammowrap { position:absolute; bottom: 28px; right: 28px; text-align:right; }
  #ammolabel { font-size: 12px; color:#9fe9ff; letter-spacing:2px; text-shadow:0 0 8px var(--neon); }
  #ammo { font-size: 34px; font-weight:800; color:#fff; text-shadow:0 0 12px var(--neon); }
  #ammo.reloading { color:#ffd27a; text-shadow:0 0 12px #ffd27a; font-size:20px; }

  #combo { position:absolute; top:50%; left:50%; transform:translate(-50%,-120px);
           font-size:26px; font-weight:800; color:#ffd27a; text-shadow:0 0 16px #ffae3a;
           opacity:0; transition:opacity .2s; }

  /* Overlays */
  #overlay { position: fixed; inset:0; z-index:10; display:flex; align-items:center; justify-content:center;
             background: radial-gradient(circle at 50% 40%, rgba(0,40,60,.55), rgba(5,6,12,.92));
             backdrop-filter: blur(3px); text-align:center; }
  #overlay.hidden { display:none; }
  .card { max-width: 560px; padding: 10px 30px; }
  h1 { font-size: 64px; font-weight: 900; letter-spacing: 6px; line-height: 1;
       background: linear-gradient(90deg,#00f0ff,#ff2e88); -webkit-background-clip:text; background-clip:text;
       color: transparent; filter: drop-shadow(0 0 18px rgba(0,240,255,.5)); }
  .sub { color:#8fb6c9; margin: 14px 0 26px; font-size: 15px; letter-spacing:1px; }
  .keys { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-bottom: 28px; }
  .key { font-size:12px; color:#bfe9ff; border:1px solid rgba(0,240,255,.3); padding:8px 12px; border-radius:8px;
         background: rgba(0,240,255,.06); }
  .key b { color:#fff; }
  #startBtn, #againBtn {
    pointer-events:auto; cursor:pointer; font-weight:800; letter-spacing:2px; font-size:18px;
    color:#05060c; background: linear-gradient(90deg,#00f0ff,#5cf0ff); border:none; padding:16px 46px;
    border-radius:10px; box-shadow:0 0 26px rgba(0,240,255,.6); transition: transform .1s, box-shadow .2s; }
  #startBtn:hover, #againBtn:hover { transform: scale(1.05); box-shadow:0 0 40px rgba(0,240,255,.9); }
  .final { font-size:18px; color:#9fe9ff; margin: 10px 0 22px; }
  .final b { color:#fff; font-size:42px; display:block; }
  #damageflash { position:fixed; inset:0; z-index:6; pointer-events:none; background:#ff2e88; opacity:0; }
  #hitmark { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%) rotate(45deg);
             font-size:22px; color:#fff; opacity:0; }
</style>
</head>
<body>
<canvas id="game"></canvas>

<div id="hud">
  <div id="crosshair"><div class="dot"></div><div id="hitmark">✕</div></div>
  <div class="panel" id="score">SCORE<b>0</b></div>
  <div class="panel" id="wave">WAVE<b>1</b></div>
  <div id="combo">COMBO x2</div>
  <div id="healthwrap"><div id="healthlabel">INTEGRITY</div><div id="healthbar"><div id="healthfill"></div></div></div>
  <div id="ammowrap"><div id="ammolabel">PLASMA</div><div id="ammo">30</div></div>
</div>

<div id="damageflash"></div>

<div id="overlay">
  <div class="card" id="startCard">
    <h1>NEON STRIKE</h1>
    <div class="sub">CLEAR THE ARENA. SURVIVE THE SWARM. CHASE THE COMBO.</div>
    <div class="keys">
      <div class="key"><b>WASD</b> Move</div>
      <div class="key"><b>MOUSE</b> Aim</div>
      <div class="key"><b>CLICK</b> Fire</div>
      <div class="key"><b>SHIFT</b> Sprint</div>
      <div class="key"><b>SPACE</b> Jump</div>
      <div class="key"><b>R</b> Reload</div>
    </div>
    <button id="startBtn">► ENTER ARENA</button>
  </div>
  <div class="card hidden" id="overCard">
    <h1 style="background:linear-gradient(90deg,#ff2e88,#ff8f5c);-webkit-background-clip:text;background-clip:text;">FLATLINED</h1>
    <div class="final">FINAL SCORE<b id="finalScore">0</b></div>
    <div class="sub" id="overSub">You reached wave 1.</div>
    <button id="againBtn">↻ RUN IT BACK</button>
  </div>
</div>

<script type="importmap">
{ "imports": { "three": "https://unpkg.com/three@0.160.0/build/three.module.js" } }
</script>

<script type="module">
import * as THREE from 'three';

// ---------------------------------------------------------------------------
// Core renderer / scene / camera
// ---------------------------------------------------------------------------
const canvas = document.getElementById('game');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x05060c);
scene.fog = new THREE.FogExp2(0x05060c, 0.018);

const camera = new THREE.PerspectiveCamera(78, window.innerWidth / window.innerHeight, 0.1, 500);

// Lights
scene.add(new THREE.AmbientLight(0x335577, 0.6));
const key = new THREE.DirectionalLight(0x88ccff, 0.8);
key.position.set(20, 40, 10);
key.castShadow = true;
key.shadow.mapSize.set(1024, 1024);
key.shadow.camera.left = -60; key.shadow.camera.right = 60;
key.shadow.camera.top = 60; key.shadow.camera.bottom = -60;
scene.add(key);
const pink = new THREE.PointLight(0xff2e88, 0.8, 120); pink.position.set(-30, 12, -20); scene.add(pink);
const cyan = new THREE.PointLight(0x00f0ff, 0.8, 120); cyan.position.set(30, 12, 20); scene.add(cyan);

// ---------------------------------------------------------------------------
// Arena
// ---------------------------------------------------------------------------
const ARENA = 70; // half-extent
const floorGeo = new THREE.PlaneGeometry(ARENA * 2, ARENA * 2);
const floorMat = new THREE.MeshStandardMaterial({ color: 0x0a0e1a, metalness: 0.7, roughness: 0.35 });
const floor = new THREE.Mesh(floorGeo, floorMat);
floor.rotation.x = -Math.PI / 2;
floor.receiveShadow = true;
scene.add(floor);

const grid = new THREE.GridHelper(ARENA * 2, 56, 0x00f0ff, 0x123);
grid.position.y = 0.02;
grid.material.transparent = true; grid.material.opacity = 0.35;
scene.add(grid);

// Glowing arena border walls
const wallMat = new THREE.MeshStandardMaterial({ color: 0x0a1426, emissive: 0x0a3a5c, emissiveIntensity: 0.6,
                                                 metalness: 0.6, roughness: 0.4 });
function makeWall(w, h, d, x, y, z) {
  const m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), wallMat);
  m.position.set(x, y, z); m.castShadow = true; m.receiveShadow = true; scene.add(m);
  // neon trim
  const trim = new THREE.Mesh(new THREE.BoxGeometry(w + 0.2, 0.4, d + 0.2),
                new THREE.MeshBasicMaterial({ color: 0x00f0ff }));
  trim.position.set(x, h, z); scene.add(trim);
  return m;
}
const wallH = 8;
makeWall(ARENA * 2, wallH, 2, 0, wallH / 2, -ARENA);
makeWall(ARENA * 2, wallH, 2, 0, wallH / 2,  ARENA);
makeWall(2, wallH, ARENA * 2, -ARENA, wallH / 2, 0);
makeWall(2, wallH, ARENA * 2,  ARENA, wallH / 2, 0);

// Obstacle pillars (cover) — also collision
const obstacles = [];
const pillarMat = new THREE.MeshStandardMaterial({ color: 0x111a30, emissive: 0xff2e88, emissiveIntensity: 0.18,
                                                   metalness: 0.5, roughness: 0.5 });
function addPillar(x, z, w, h, d) {
  const m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), pillarMat);
  m.position.set(x, h / 2, z); m.castShadow = true; m.receiveShadow = true; scene.add(m);
  const cap = new THREE.Mesh(new THREE.BoxGeometry(w + .3, .3, d + .3),
              new THREE.MeshBasicMaterial({ color: 0xff2e88 }));
  cap.position.set(x, h, z); scene.add(cap);
  obstacles.push({ mesh: m, hw: w / 2, hd: d / 2, h });
}
const pillarLayout = [
  [-22, -18, 5, 10, 5], [24, -22, 6, 14, 6], [18, 20, 5, 9, 5], [-26, 24, 6, 12, 6],
  [0, 0, 8, 6, 8], [-40, -2, 4, 16, 4], [40, 8, 4, 18, 4], [6, -38, 5, 8, 12], [-10, 40, 12, 7, 5],
];
pillarLayout.forEach(p => addPillar(...p));

// ---------------------------------------------------------------------------
// Audio (synthesized — no asset files)
// ---------------------------------------------------------------------------
let audioCtx = null;
function initAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
function beep({ freq = 440, type = 'square', dur = 0.08, vol = 0.15, slideTo = null }) {
  if (!audioCtx) return;
  const o = audioCtx.createOscillator(), g = audioCtx.createGain();
  o.type = type; o.frequency.setValueAtTime(freq, audioCtx.currentTime);
  if (slideTo) o.frequency.exponentialRampToValueAtTime(slideTo, audioCtx.currentTime + dur);
  g.gain.setValueAtTime(vol, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + dur);
  o.connect(g); g.connect(audioCtx.destination);
  o.start(); o.stop(audioCtx.currentTime + dur);
}
function noiseBurst(dur = 0.18, vol = 0.25) {
  if (!audioCtx) return;
  const n = audioCtx.sampleRate * dur;
  const buf = audioCtx.createBuffer(1, n, audioCtx.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < n; i++) d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / n, 2);
  const src = audioCtx.createBufferSource(); src.buffer = buf;
  const g = audioCtx.createGain(); g.gain.value = vol;
  const f = audioCtx.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = 1800;
  src.connect(f); f.connect(g); g.connect(audioCtx.destination); src.start();
}
const sfx = {
  shoot: () => beep({ freq: 720, slideTo: 180, type: 'sawtooth', dur: 0.09, vol: 0.12 }),
  hit:   () => beep({ freq: 320, slideTo: 120, type: 'square', dur: 0.06, vol: 0.10 }),
  kill:  () => { beep({ freq: 200, slideTo: 600, type: 'square', dur: 0.12, vol: 0.16 }); noiseBurst(0.15, 0.18); },
  hurt:  () => { beep({ freq: 160, slideTo: 60, type: 'sawtooth', dur: 0.2, vol: 0.2 }); },
  reload:() => beep({ freq: 300, slideTo: 520, type: 'triangle', dur: 0.18, vol: 0.12 }),
  wave:  () => { beep({ freq: 440, slideTo: 880, type: 'triangle', dur: 0.3, vol: 0.14 }); },
  empty: () => beep({ freq: 120, type: 'square', dur: 0.05, vol: 0.08 }),
};

// ---------------------------------------------------------------------------
// Player & controls (pointer lock FPS)
// ---------------------------------------------------------------------------
const player = {
  pos: new THREE.Vector3(0, 1.7, 30),
  vel: new THREE.Vector3(),
  yaw: Math.PI, pitch: 0,
  onGround: true,
  hp: 100, maxHp: 100,
  radius: 1.0, height: 1.7,
};
const EYE = 1.7;

const keys = {};
let pointerLocked = false;
let mouseDown = false;

document.addEventListener('keydown', e => {
  keys[e.code] = true;
  if (e.code === 'KeyR') reload();
  if (e.code === 'Space') e.preventDefault();
});
document.addEventListener('keyup', e => { keys[e.code] = false; });

canvas.addEventListener('mousedown', () => { mouseDown = true; });
document.addEventListener('mouseup', () => { mouseDown = false; });

document.addEventListener('pointerlockchange', () => {
  pointerLocked = document.pointerLockElement === canvas;
});
document.addEventListener('mousemove', e => {
  if (!pointerLocked) return;
  const sens = 0.0022;
  player.yaw   -= e.movementX * sens;
  player.pitch -= e.movementY * sens;
  const lim = Math.PI / 2 - 0.05;
  player.pitch = Math.max(-lim, Math.min(lim, player.pitch));
});

// ---------------------------------------------------------------------------
// Weapon viewmodel
// ---------------------------------------------------------------------------
const gun = new THREE.Group();
const gunBody = new THREE.Mesh(new THREE.BoxGeometry(0.18, 0.18, 0.7),
  new THREE.MeshStandardMaterial({ color: 0x141a2a, metalness: 0.8, roughness: 0.3,
                                   emissive: 0x00343f, emissiveIntensity: 0.5 }));
gunBody.position.set(0.28, -0.26, -0.6);
gun.add(gunBody);
const gunGlow = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.06, 0.5),
  new THREE.MeshBasicMaterial({ color: 0x00f0ff }));
gunGlow.position.set(0.28, -0.21, -0.7);
gun.add(gunGlow);
const muzzle = new THREE.Mesh(new THREE.SphereGeometry(0.16, 8, 8),
  new THREE.MeshBasicMaterial({ color: 0xffffff }));
muzzle.position.set(0.28, -0.26, -1.0); muzzle.visible = false;
gun.add(muzzle);
const muzzleLight = new THREE.PointLight(0x00f0ff, 0, 8);
muzzleLight.position.copy(muzzle.position);
gun.add(muzzleLight);
camera.add(gun);
scene.add(camera);

// ---------------------------------------------------------------------------
// Weapon state
// ---------------------------------------------------------------------------
const weapon = { mag: 30, magSize: 30, fireRate: 0.085, damage: 34, lastShot: 0, reloading: false, reloadTime: 1.1, range: 200, spread: 0.012 };
let gunRecoil = 0;

function reload() {
  if (weapon.reloading || weapon.mag === weapon.magSize || !state.running) return;
  weapon.reloading = true;
  sfx.reload();
  setReloadUI(true);
  setTimeout(() => {
    weapon.mag = weapon.magSize;
    weapon.reloading = false;
    setReloadUI(false);
    updateAmmoUI();
  }, weapon.reloadTime * 1000);
}

// ---------------------------------------------------------------------------
// Tracers & particles pools
// ---------------------------------------------------------------------------
const tracers = [];
function spawnTracer(from, to) {
  const geo = new THREE.BufferGeometry().setFromPoints([from, to]);
  const mat = new THREE.LineBasicMaterial({ color: 0x9ff6ff, transparent: true, opacity: 0.9 });
  const line = new THREE.Line(geo, mat);
  scene.add(line);
  tracers.push({ line, life: 0.06 });
}

const particles = [];
function burst(pos, color, count = 18, speed = 16) {
  for (let i = 0; i < count; i++) {
    const g = new THREE.Mesh(new THREE.BoxGeometry(0.22, 0.22, 0.22),
      new THREE.MeshBasicMaterial({ color }));
    g.position.copy(pos);
    const dir = new THREE.Vector3(Math.random() * 2 - 1, Math.random() * 2 - 1, Math.random() * 2 - 1).normalize();
    scene.add(g);
    particles.push({ mesh: g, vel: dir.multiplyScalar(speed * (0.4 + Math.random() * 0.6)), life: 0.6 + Math.random() * 0.4 });
  }
}

// ---------------------------------------------------------------------------
// Enemies
// ---------------------------------------------------------------------------
const enemies = [];
const enemyGeo = new THREE.IcosahedronGeometry(1.1, 0);
function spawnEnemy(wave) {
  // spawn at arena edge away from player
  let x, z, tries = 0;
  do {
    const a = Math.random() * Math.PI * 2;
    const r = ARENA - 6;
    x = Math.cos(a) * r; z = Math.sin(a) * r;
    tries++;
  } while (Math.hypot(x - player.pos.x, z - player.pos.z) < 25 && tries < 12);

  const hue = Math.random() < 0.5 ? 0xff2e88 : 0xff8f3a;
  const mat = new THREE.MeshStandardMaterial({ color: 0x1a0a16, emissive: hue, emissiveIntensity: 0.9,
                                               metalness: 0.4, roughness: 0.3, flatShading: true });
  const mesh = new THREE.Mesh(enemyGeo, mat);
  mesh.position.set(x, 1.6, z);
  mesh.castShadow = true;
  // glowing core
  const core = new THREE.Mesh(new THREE.SphereGeometry(0.45, 8, 8), new THREE.MeshBasicMaterial({ color: hue }));
  mesh.add(core);
  const light = new THREE.PointLight(hue, 0.6, 10); mesh.add(light);
  scene.add(mesh);

  const speedBoost = 1 + wave * 0.06;
  enemies.push({
    mesh, core,
    hp: 50 + wave * 12,
    maxHp: 50 + wave * 12,
    speed: (5.5 + Math.random() * 2.5) * speedBoost,
    radius: 1.3,
    spin: Math.random() * 2 - 1,
    bob: Math.random() * Math.PI * 2,
    color: hue,
    damageTimer: 0,
  });
}

// ---------------------------------------------------------------------------
// Game state & waves
// ---------------------------------------------------------------------------
const state = {
  running: false,
  score: 0,
  wave: 0,
  toSpawn: 0,
  spawnTimer: 0,
  alive: 0,
  combo: 1,
  comboTimer: 0,
  betweenWaves: 0,
};

function startWave(n) {
  state.wave = n;
  state.toSpawn = 4 + Math.floor(n * 1.7);
  state.spawnTimer = 0;
  state.alive = state.toSpawn;
  document.querySelector('#wave b').textContent = n;
  sfx.wave();
  flashCombo(`WAVE ${n}`, '#9fe9ff');
}

function nextWaveCheck() {
  if (state.running && state.toSpawn === 0 && enemies.length === 0 && state.betweenWaves <= 0) {
    state.betweenWaves = 2.5;
  }
}

// ---------------------------------------------------------------------------
// HUD helpers
// ---------------------------------------------------------------------------
const ui = {
  score: document.querySelector('#score b'),
  health: document.getElementById('healthfill'),
  ammo: document.getElementById('ammo'),
  combo: document.getElementById('combo'),
  flash: document.getElementById('damageflash'),
  hitmark: document.getElementById('hitmark'),
};
function updateScoreUI() { ui.score.textContent = state.score; }
function updateHealthUI() { ui.health.style.width = Math.max(0, player.hp / player.maxHp * 100) + '%'; }
function updateAmmoUI() { if (!weapon.reloading) ui.ammo.textContent = weapon.mag; }
function setReloadUI(on) {
  ui.ammo.classList.toggle('reloading', on);
  ui.ammo.textContent = on ? 'RELOADING' : weapon.mag;
}
let comboTO;
function flashCombo(txt, color) {
  ui.combo.textContent = txt; ui.combo.style.color = color || '#ffd27a';
  ui.combo.style.opacity = 1;
  clearTimeout(comboTO);
  comboTO = setTimeout(() => ui.combo.style.opacity = 0, 800);
}
function damageFlash() {
  ui.flash.style.transition = 'none'; ui.flash.style.opacity = 0.5;
  requestAnimationFrame(() => { ui.flash.style.transition = 'opacity .4s'; ui.flash.style.opacity = 0; });
}
let hitTO;
function showHitmark() {
  ui.hitmark.style.transition = 'none'; ui.hitmark.style.opacity = 1;
  clearTimeout(hitTO);
  hitTO = setTimeout(() => { ui.hitmark.style.transition = 'opacity .25s'; ui.hitmark.style.opacity = 0; }, 60);
}

// ---------------------------------------------------------------------------
// Shooting (hitscan via raycaster)
// ---------------------------------------------------------------------------
const raycaster = new THREE.Raycaster();
const forward = new THREE.Vector3();
const clock = new THREE.Clock();

function shoot() {
  const now = clock.elapsedTime;
  if (weapon.reloading || now - weapon.lastShot < weapon.fireRate) return;
  if (weapon.mag <= 0) { sfx.empty(); reload(); return; }
  weapon.lastShot = now;
  weapon.mag--;
  updateAmmoUI();
  sfx.shoot();
  gunRecoil = 0.12;

  // muzzle flash
  muzzle.visible = true; muzzleLight.intensity = 3;
  setTimeout(() => { muzzle.visible = false; muzzleLight.intensity = 0; }, 40);

  // direction with slight spread
  camera.getWorldDirection(forward);
  const spread = weapon.spread;
  forward.x += (Math.random() - 0.5) * spread;
  forward.y += (Math.random() - 0.5) * spread;
  forward.z += (Math.random() - 0.5) * spread;
  forward.normalize();

  const origin = camera.getWorldPosition(new THREE.Vector3());
  raycaster.set(origin, forward);
  raycaster.far = weapon.range;

  const enemyMeshes = enemies.map(e => e.mesh);
  const hits = raycaster.intersectObjects([...enemyMeshes, ...obstacles.map(o => o.mesh), floor, ...scene.children.filter(c => c.geometry && c.material === wallMat)], false);

  let endPoint = origin.clone().add(forward.clone().multiplyScalar(weapon.range));
  if (hits.length) {
    const hit = hits[0];
    endPoint = hit.point.clone();
    const enemy = enemies.find(e => e.mesh === hit.object);
    if (enemy) {
      enemy.hp -= weapon.damage;
      enemy.damageTimer = 0.12;
      showHitmark();
      sfx.hit();
      burst(hit.point, enemy.color, 6, 10);
      if (enemy.hp <= 0) killEnemy(enemy);
    } else {
      burst(hit.point, 0x66ccff, 4, 8);
    }
  }
  // tracer from gun muzzle world pos to endpoint
  const muzzleWorld = muzzle.getWorldPosition(new THREE.Vector3());
  spawnTracer(muzzleWorld, endPoint);
}

function killEnemy(enemy) {
  burst(enemy.mesh.position, enemy.color, 26, 20);
  scene.remove(enemy.mesh);
  const idx = enemies.indexOf(enemy);
  if (idx >= 0) enemies.splice(idx, 1);
  sfx.kill();

  // combo
  state.comboTimer = 3.0;
  state.combo = Math.min(state.combo + 1, 99);
  const gained = 100 * state.combo;
  state.score += gained;
  updateScoreUI();
  if (state.combo > 1) flashCombo(`COMBO x${state.combo}  +${gained}`, '#ffd27a');
}

// ---------------------------------------------------------------------------
// Collision helper (player/enemy vs pillars + arena)
// ---------------------------------------------------------------------------
function collideArena(pos, radius) {
  const lim = ARENA - 2 - radius;
  pos.x = Math.max(-lim, Math.min(lim, pos.x));
  pos.z = Math.max(-lim, Math.min(lim, pos.z));
  for (const o of obstacles) {
    const minX = o.mesh.position.x - o.hw - radius, maxX = o.mesh.position.x + o.hw + radius;
    const minZ = o.mesh.position.z - o.hd - radius, maxZ = o.mesh.position.z + o.hd + radius;
    if (pos.x > minX && pos.x < maxX && pos.z > minZ && pos.z < maxZ) {
      // push out along the smallest penetration axis
      const dxL = pos.x - minX, dxR = maxX - pos.x, dzL = pos.z - minZ, dzR = maxZ - pos.z;
      const m = Math.min(dxL, dxR, dzL, dzR);
      if (m === dxL) pos.x = minX; else if (m === dxR) pos.x = maxX;
      else if (m === dzL) pos.z = minZ; else pos.z = maxZ;
    }
  }
}

// ---------------------------------------------------------------------------
// Update loop
// ---------------------------------------------------------------------------
const GRAVITY = 24;
const JUMP_V = 8.5;

function update(dt) {
  // ---- player movement ----
  const sprint = keys['ShiftLeft'] || keys['ShiftRight'];
  const speed = (sprint ? 13 : 8.5);
  const sinY = Math.sin(player.yaw), cosY = Math.cos(player.yaw);
  // forward vector on XZ (yaw=PI faces -... we map so W goes where you look)
  const fx = -sinY, fz = -cosY;
  const rx =  cosY, rz = -sinY;
  let mx = 0, mz = 0;
  if (keys['KeyW']) { mx += fx; mz += fz; }
  if (keys['KeyS']) { mx -= fx; mz -= fz; }
  if (keys['KeyD']) { mx += rx; mz += rz; }
  if (keys['KeyA']) { mx -= rx; mz -= rz; }
  const len = Math.hypot(mx, mz);
  if (len > 0) { mx /= len; mz /= len; }

  // smooth horizontal velocity
  const targetVx = mx * speed, targetVz = mz * speed;
  const accel = player.onGround ? 14 : 5;
  player.vel.x += (targetVx - player.vel.x) * Math.min(1, accel * dt);
  player.vel.z += (targetVz - player.vel.z) * Math.min(1, accel * dt);

  // jump + gravity
  if ((keys['Space']) && player.onGround) { player.vel.y = JUMP_V; player.onGround = false; sfx.reload && beep({freq:300,slideTo:600,type:'sine',dur:0.08,vol:0.07}); }
  player.vel.y -= GRAVITY * dt;

  player.pos.x += player.vel.x * dt;
  player.pos.z += player.vel.z * dt;
  player.pos.y += player.vel.y * dt;
  if (player.pos.y <= EYE) { player.pos.y = EYE; player.vel.y = 0; player.onGround = true; }

  collideArena(player.pos, player.radius);

  // camera placement
  camera.position.copy(player.pos);
  const cp = Math.cos(player.pitch);
  const dir = new THREE.Vector3(-Math.sin(player.yaw) * cp, Math.sin(player.pitch), -Math.cos(player.yaw) * cp);
  camera.lookAt(camera.position.clone().add(dir));

  // gun recoil/sway
  gunRecoil = Math.max(0, gunRecoil - dt * 0.6);
  gun.position.z = gunRecoil * 0.5;
  gun.position.y = -Math.abs(Math.sin(clock.elapsedTime * (sprint ? 14 : 8))) * (len > 0 ? 0.02 : 0.006);

  // ---- shooting ----
  if (mouseDown && pointerLocked) shoot();

  // ---- enemies ----
  for (const e of enemies) {
    const toP = new THREE.Vector3(player.pos.x - e.mesh.position.x, 0, player.pos.z - e.mesh.position.z);
    const dist = toP.length();
    toP.normalize();
    e.mesh.position.x += toP.x * e.speed * dt;
    e.mesh.position.z += toP.z * e.speed * dt;
    e.bob += dt * 3;
    e.mesh.position.y = 1.6 + Math.sin(e.bob) * 0.3;
    e.mesh.rotation.y += e.spin * dt * 2;
    e.mesh.rotation.x += e.spin * dt;
    collideArena(e.mesh.position, e.radius);

    // damage flash
    if (e.damageTimer > 0) {
      e.damageTimer -= dt;
      e.mesh.material.emissiveIntensity = 2.2;
      e.mesh.scale.setScalar(1.15);
    } else {
      e.mesh.material.emissiveIntensity = 0.9;
      e.mesh.scale.setScalar(1);
    }

    // attack player
    if (dist < e.radius + player.radius + 0.4) {
      if (!e._cool || clock.elapsedTime - e._cool > 0.6) {
        e._cool = clock.elapsedTime;
        damagePlayer(12);
        // knockback
        e.mesh.position.x -= toP.x * 2; e.mesh.position.z -= toP.z * 2;
      }
    }
  }

  // separate enemies a bit so they don't fully stack
  for (let i = 0; i < enemies.length; i++) {
    for (let j = i + 1; j < enemies.length; j++) {
      const a = enemies[i].mesh.position, b = enemies[j].mesh.position;
      const dx = b.x - a.x, dz = b.z - a.z; const d = Math.hypot(dx, dz);
      const min = enemies[i].radius + enemies[j].radius;
      if (d > 0 && d < min) {
        const push = (min - d) / 2 / d;
        a.x -= dx * push; a.z -= dz * push; b.x += dx * push; b.z += dz * push;
      }
    }
  }

  // ---- spawning ----
  if (state.betweenWaves > 0) {
    state.betweenWaves -= dt;
    if (state.betweenWaves <= 0) startWave(state.wave + 1);
  }
  if (state.toSpawn > 0) {
    state.spawnTimer -= dt;
    if (state.spawnTimer <= 0) {
      spawnEnemy(state.wave);
      state.toSpawn--;
      state.spawnTimer = Math.max(0.25, 1.0 - state.wave * 0.03);
    }
  }
  nextWaveCheck();

  // ---- combo decay ----
  if (state.comboTimer > 0) { state.comboTimer -= dt; if (state.comboTimer <= 0) state.combo = 1; }

  // ---- tracers ----
  for (let i = tracers.length - 1; i >= 0; i--) {
    const t = tracers[i]; t.life -= dt;
    t.line.material.opacity = Math.max(0, t.life / 0.06) * 0.9;
    if (t.life <= 0) { scene.remove(t.line); t.line.geometry.dispose(); t.line.material.dispose(); tracers.splice(i, 1); }
  }
  // ---- particles ----
  for (let i = particles.length - 1; i >= 0; i--) {
    const p = particles[i]; p.life -= dt;
    p.vel.y -= 30 * dt;
    p.mesh.position.addScaledVector(p.vel, dt);
    p.mesh.rotation.x += dt * 8; p.mesh.rotation.y += dt * 6;
    const s = Math.max(0.01, p.life);
    p.mesh.scale.setScalar(s);
    if (p.life <= 0) { scene.remove(p.mesh); p.mesh.geometry.dispose(); p.mesh.material.dispose(); particles.splice(i, 1); }
  }

  // pulse arena lights
  const t = clock.elapsedTime;
  pink.intensity = 0.7 + Math.sin(t * 2) * 0.2;
  cyan.intensity = 0.7 + Math.cos(t * 2.3) * 0.2;
}

function damagePlayer(amt) {
  if (!state.running) return;
  player.hp -= amt;
  updateHealthUI();
  damageFlash();
  sfx.hurt();
  state.combo = 1; state.comboTimer = 0;
  if (player.hp <= 0) { player.hp = 0; updateHealthUI(); gameOver(); }
}

// ---------------------------------------------------------------------------
// Loop
// ---------------------------------------------------------------------------
function animate() {
  requestAnimationFrame(animate);
  const dt = Math.min(0.05, clock.getDelta());
  if (state.running) update(dt);
  renderer.render(scene, camera);
}
animate();

// ---------------------------------------------------------------------------
// Start / restart / game over
// ---------------------------------------------------------------------------
const overlay = document.getElementById('overlay');
const startCard = document.getElementById('startCard');
const overCard = document.getElementById('overCard');

function resetGame() {
  // clear enemies/particles/tracers
  enemies.forEach(e => scene.remove(e.mesh)); enemies.length = 0;
  particles.forEach(p => scene.remove(p.mesh)); particles.length = 0;
  tracers.forEach(t => scene.remove(t.line)); tracers.length = 0;

  player.pos.set(0, EYE, 30); player.vel.set(0, 0, 0);
  player.yaw = Math.PI; player.pitch = 0; player.hp = player.maxHp; player.onGround = true;
  weapon.mag = weapon.magSize; weapon.reloading = false; setReloadUI(false);
  state.score = 0; state.wave = 0; state.combo = 1; state.comboTimer = 0;
  state.toSpawn = 0; state.alive = 0; state.betweenWaves = 0;
  updateScoreUI(); updateHealthUI(); updateAmmoUI();
}

function startGame() {
  initAudio();
  if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
  resetGame();
  overlay.classList.add('hidden');
  state.running = true;
  canvas.requestPointerLock();
  startWave(1);
}

function gameOver() {
  state.running = false;
  document.exitPointerLock();
  document.getElementById('finalScore').textContent = state.score;
  document.getElementById('overSub').textContent = `You reached wave ${state.wave}.`;
  startCard.classList.add('hidden');
  overCard.classList.remove('hidden');
  overlay.classList.remove('hidden');
}

document.getElementById('startBtn').addEventListener('click', startGame);
document.getElementById('againBtn').addEventListener('click', () => {
  overCard.classList.add('hidden'); startCard.classList.remove('hidden'); startGame();
});

// Re-acquire pointer lock on click if game running but unlocked (e.g. user hit Esc)
canvas.addEventListener('click', () => {
  if (state.running && !pointerLocked) canvas.requestPointerLock();
});

// ---------------------------------------------------------------------------
// Resize
// ---------------------------------------------------------------------------
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});
</script>
</body>
</html>
